# Supabase — get these from: Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Storage bucket name (must match what you created in setup.sql)
CV_UPLOADS_BUCKET=cv-uploads

# MiniMax via Anthropic-compatible endpoint
# Key: https://platform.minimaxi.com/  |  Docs: https://api.minimax.io/anthropic
ANTHROPIC_API_KEY=your-minimax-api-key-here
ANTHROPIC_BASE_URL=https://api.minimax.io/anthropic
ANTHROPIC_MODEL=MiniMax-M2.7

# Optional auth header — leave blank to disable
API_SECRET=

# Server
HOST=0.0.0.0
PORT=8000
